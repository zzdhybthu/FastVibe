{
  "name": "vibecoding-v2",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @vibecoding/server dev",
    "dev:web": "pnpm --filter @vibecoding/web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @vibecoding/server start",
    "clean": "rm -rf server/dist web/dist shared/dist",
    "clean:all": "pnpm clean && rm -rf node_modules server/node_modules web/node_modules shared/node_modules",
    "clean:db": "rm -rf server/data",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
