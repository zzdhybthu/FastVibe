FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System packages (no python3 — uv manages Python)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates openssh-client ripgrep build-essential \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (official installer)
RUN curl -fsSL https://claude.ai/install.sh | bash

# uv (Python version + package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
RUN /root/.local/bin/uv python install 3.10 3.11 3.12 3.13

# fnm (Node version manager) + pre-install Node versions
RUN curl -fsSL https://fnm.vercel.app/install | bash
ENV PATH="/root/.local/share/fnm:$PATH"
SHELL ["/bin/bash", "-c"]
RUN eval "$(fnm env)" && \
    fnm install 22 && fnm install 20 && fnm install 18 && \
    fnm default 22

# corepack + pnpm
RUN eval "$(fnm env)" && corepack enable && corepack prepare pnpm@latest --activate

# Static PATH (docker exec is non-interactive, won't eval fnm env)
ENV PATH="/root/.local/share/fnm/aliases/default/bin:/root/.local/bin:/root/.local/share/fnm:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# GitHub SSH host keys (avoid first-connect confirmation)
RUN mkdir -p /root/.ssh && \
    ssh-keyscan github.com >> /root/.ssh/known_hosts 2>/dev/null && \
    chmod 700 /root/.ssh && chmod 644 /root/.ssh/known_hosts

WORKDIR /workspace
CMD ["sleep", "infinity"]
